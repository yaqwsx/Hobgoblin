{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hobgoblin",
  "version": "0.1.0",
  "identifier": "dev.hobgoblin.cam",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hobgoblin",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
